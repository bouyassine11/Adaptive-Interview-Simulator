# Database
# Local: postgresql://skilladapt:skilladapt@localhost:5432/skilladapt
# Neon: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://skilladapt:skilladapt@localhost:5432/skilladapt"

# NextAuth
AUTH_SECRET="generate with: npx auth secret"
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Hugging Face (get token from https://huggingface.co/settings/tokens)
# Optional — grading degrades gracefully if not set
HF_API_TOKEN="your-huggingface-api-token"

# Optional: NextAuth URL (set in production)
# AUTH_URL="https://your-domain.vercel.app"
